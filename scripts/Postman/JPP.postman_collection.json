{
  "info": {
    "name": "Job Processing Platform API",
    "description": "Collection for testing the Job Processing Platform locally via docker-compose (health, job submit, job status, list jobs).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Create Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"image\",\n  \"payload\": \"{\\\"url\\\": \\\"https://example.com/image.jpg\\\"}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/jobs",
          "host": ["{{baseUrl}}"],
          "path": ["jobs"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "// Save jobId to the active environment for follow-up requests",
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData.id) {",
              "  pm.environment.set('jobId', jsonData.id);",
              "}",
              ""
            ]
          }
        }
      ]
    },
    {
      "name": "Get Job by ID (env jobId)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{jobId}}",
          "host": ["{{baseUrl}}"],
          "path": ["jobs", "{{jobId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Job by ID (manual)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["jobs", "00000000-0000-0000-0000-000000000000"]
        }
      },
      "response": []
    },
    {
      "name": "List Jobs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs",
          "host": ["{{baseUrl}}"],
          "path": ["jobs"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
